# ============================================================
# 경찰청 습득물 AI 검색 시스템 환경변수 설정
# .env.example을 복사해서 .env 파일로 만들고 값을 채워주세요
# ============================================================

# OpenAI API (PydanticAI 에이전트용)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# 경찰청 공공데이터포털 API 키
# https://www.data.go.kr 에서 "경찰청_습득물 관리 현황" 서비스 신청
# 발급받은 키는 URL 디코딩된 값(Encoding 제거)을 그대로 입력
POLICE_API_KEY=your_decoded_service_key_here

# Qdrant 벡터 DB (docker-compose로 실행)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=lost_items

# 앱 설정
APP_ENV=development
LOG_LEVEL=INFO

# CLIP 임베딩 모델 (sentence-transformers가 자동 다운로드, ~350MB)
CLIP_MODEL_NAME=clip-ViT-B-32
EMBEDDING_DIM=512
